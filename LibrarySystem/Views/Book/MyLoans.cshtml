@model IEnumerable<LibrarySystem.Models.BookLoan>
@{
    ViewData["Title"] = "Моите заемания";
}

<div style="background:#5c3d2e;padding:2rem 1.5rem">
    <p style="font-size:11px;text-transform:uppercase;letter-spacing:.1em;color:rgba(245,230,211,0.5);margin-bottom:4px">Профил</p>
    <h1 style="font-size:22px;font-weight:500;color:#f5e6d3;margin-bottom:2px">Моите заемания</h1>
    <p style="font-size:13px;color:rgba(245,230,211,0.55)">@Model.Count(l => !l.IsReturned) активни заемания</p>
</div>

<div class="container-fluid py-4" style="background:#faf7f2;min-height:60vh">
    @if (!Model.Any())
    {
        <div style="text-align:center;padding:3rem;color:#a08060">
            <p style="font-size:15px">Нямате активни заемания.</p>
            <a asp-controller="Book" asp-action="Index" class="btn mt-2"
               style="background:#5c3d2e;border-color:#5c3d2e;color:#f5e6d3;font-size:14px">Разгледай книги</a>
        </div>
    }
    else
    {
        <div class="row g-3">
            @foreach (var loan in Model)
            {
                bool isOverdue = !loan.IsReturned && loan.DueDate < DateTime.UtcNow;
                <div class="col-md-4">
                    <div class="card h-100" style="border:1px solid #e8e0d5;border-radius:10px;overflow:hidden;background:#fff">
                        <div style="height:3px;background:@(loan.IsReturned ? "#d5c5b0" : isOverdue ? "#c0392b" : "#c5956a")"></div>
                        <div class="card-body pb-2">
                            <h5 style="font-size:15px;font-weight:500;color:#2c1810;margin-bottom:2px">@loan.Book.Title</h5>
                            <p style="font-size:13px;color:#a08060;margin-bottom:.75rem">
                                @loan.Book.Author.FirstName @loan.Book.Author.LastName
                            </p>
                            <div style="font-size:12px;color:#888;margin-bottom:4px">
                                Заето на: @loan.LoanDate.ToLocalTime().ToString("dd.MM.yyyy")
                            </div>
                            <div style="font-size:12px;color:@(isOverdue ? "#c0392b" : "#888")">
                                Краен срок: @loan.DueDate.ToLocalTime().ToString("dd.MM.yyyy")
                            </div>
                        </div>
                        <div class="card-footer d-flex align-items-center justify-content-between"
                             style="background:#fff;border-top:1px solid #f0e8dc">
                            @if (loan.IsReturned)
                            {
                                <span style="font-size:12px;color:#a08060">Върната на @loan.ReturnDate?.ToLocalTime().ToString("dd.MM.yyyy")</span>
                            }
                            else if (isOverdue)
                            {
                                <span style="font-size:12px;color:#c0392b;font-weight:500">Просрочена!</span>
                                <form asp-action="Return" asp-route-id="@loan.BookId" method="post">
                                    <button type="submit" class="btn btn-sm"
                                            style="background:#5c3d2e;border-color:#5c3d2e;color:#f5e6d3;font-size:13px">
                                        Върни
                                    </button>
                                </form>
                            }
                            else
                            {
                                <span style="font-size:12px;color:#888">Активна</span>
                                <form asp-action="Return" asp-route-id="@loan.BookId" method="post">
                                    <button type="submit" class="btn btn-sm"
                                            style="background:#5c3d2e;border-color:#5c3d2e;color:#f5e6d3;font-size:13px">
                                        Върни
                                    </button>
                                </form>
                            }
                        </div>
                    </div>
                </div>
            }
        </div>
    }
</div>