@model IEnumerable<LibrarySystem.Models.Book>
@{
    ViewData["Title"] = "Книги";
}

<div style="background:#5c3d2e;padding:2rem 1.5rem">
    <p style="font-size:11px;text-transform:uppercase;letter-spacing:.1em;color:rgba(245,230,211,0.5);margin-bottom:4px">Каталог</p>
    <h1 style="font-size:22px;font-weight:500;color:#f5e6d3;margin-bottom:2px">Книги</h1>
    <p style="font-size:13px;color:rgba(245,230,211,0.55)">@Model.Count() заглавия в системата</p>
</div>

<div style="background:#fff;border-bottom:1px solid #e8e0d5;padding:1rem 1.5rem">
    <form method="get" asp-action="Index" class="d-flex gap-2 flex-wrap">
        <input type="text"
               name="search"
               value="@ViewBag.CurrentSearch"
               placeholder="Търси по заглавие или автор..."
               class="form-control"
               style="max-width:280px;border-color:#e8e0d5;font-size:14px" />

        <select name="genreId"
                class="form-select"
                style="max-width:180px;border-color:#e8e0d5;font-size:14px">
            <option value="">Всички жанрове</option>
            @foreach (var genre in ViewBag.Genres)
            {
                <option value="@genre.Id"
                        selected="@(ViewBag.CurrentGenre == genre.Id)">
                    @genre.Name
                </option>
            }
        </select>

        <button type="submit" class="btn"
                style="background:#5c3d2e;border-color:#5c3d2e;color:#f5e6d3;font-size:14px">
            Търси
        </button>

        @if (ViewBag.CurrentSearch != null || ViewBag.CurrentGenre != null)
        {
            <a asp-action="Index" class="btn"
                   style="border:1px solid #d5c5b0;color:#5c3d2e;background:#fff;font-size:14px">
                Изчисти
            </a>
        }
    </form>
</div>

<div class="container-fluid py-4" style="background:#faf7f2;min-height:60vh">
    <div class="row g-3">
        @foreach (var book in Model)
        {
            <div class="col-md-4">
                <div class="card h-100" style="border:1px solid #e8e0d5;border-radius:10px;overflow:hidden;background:#fff">
                    <div style="height:3px;background:#c5956a"></div>
                    <div class="card-body pb-2">
                        <h5 style="font-size:15px;font-weight:500;color:#2c1810;margin-bottom:2px">@book.Title</h5>
                        <p style="font-size:13px;color:#a08060;margin-bottom:.6rem">@book.Author.FirstName @book.Author.LastName</p>
                        <span style="display:inline-block;font-size:11px;background:#f5ede0;color:#7a5c3a;padding:2px 9px;border-radius:4px;font-weight:500">@book.Genre.Name</span>
                        <p style="font-size:12px;color:#bbb;margin-top:.6rem;margin-bottom:0">@book.AvailableCopies / @book.TotalCopies налични</p>
                    </div>
                    <div class="card-footer d-flex gap-2" style="background:#fff;border-top:1px solid #f0e8dc">
                        <a asp-action="Details" asp-route-id="@book.Id"
                           class="btn btn-sm" style="border:1px solid #d5c5b0;color:#5c3d2e;background:#fff">Детайли</a>
                        @if (book.IsAvailable)
                        {
                            <form asp-action="Loan" asp-route-id="@book.Id" method="post">
                                <button type="submit" class="btn btn-sm"
                                        style="background:#5c3d2e;border-color:#5c3d2e;color:#f5e6d3">
                                    Заеми
                                </button>
                            </form>
                        }
                        else
                        {
                            <span class="badge align-self-center" style="background:#f5ede0;color:#a08060">Изчерпана</span>
                        }
                    </div>
                </div>
            </div>
        }
    </div>
</div>