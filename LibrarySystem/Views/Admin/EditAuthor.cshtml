@model LibrarySystem.Models.Author
@{
    ViewData["Title"] = "Редактирай автор";
}

<div style="background:#5c3d2e;padding:2rem 1.5rem">
    <p style="font-size:11px;text-transform:uppercase;letter-spacing:.1em;color:rgba(245,230,211,0.5);margin-bottom:4px">Администрация</p>
    <h1 style="font-size:22px;font-weight:500;color:#f5e6d3;margin-bottom:0">Редактирай автор</h1>
</div>

<div class="container-fluid py-4" style="background:#faf7f2;min-height:60vh">
    <div style="max-width:420px;background:#fff;border:1px solid #e8e0d5;border-radius:10px;padding:1.5rem">
        <form asp-action="EditAuthor" method="post">
            <input asp-for="Id" type="hidden" />
            <div asp-validation-summary="ModelOnly" class="alert alert-danger" style="font-size:13px"></div>
            <div class="mb-3">
                <label asp-for="FirstName" style="font-size:13px;color:#7a5c3a;font-weight:500">Име</label>
                <input asp-for="FirstName" class="form-control mt-1" style="border-color:#e8e0d5;font-size:14px" />
                <span asp-validation-for="FirstName" class="text-danger" style="font-size:12px"></span>
            </div>
            <div class="mb-4">
                <label asp-for="LastName" style="font-size:13px;color:#7a5c3a;font-weight:500">Фамилия</label>
                <input asp-for="LastName" class="form-control mt-1" style="border-color:#e8e0d5;font-size:14px" />
                <span asp-validation-for="LastName" class="text-danger" style="font-size:12px"></span>
            </div>
            <div class="d-flex gap-2">
                <button type="submit" class="btn"
                        style="background:#5c3d2e;border-color:#5c3d2e;color:#f5e6d3;font-size:14px">
                    Запази
                </button>
                <a asp-action="Authors" class="btn"
                   style="border:1px solid #d5c5b0;color:#5c3d2e;background:#fff;font-size:14px">Назад</a>
            </div>
        </form>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}