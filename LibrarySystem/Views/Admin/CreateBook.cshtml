@model LibrarySystem.Models.Book
@{
    ViewData["Title"] = "Добави книга";
}

<div style="background:#5c3d2e;padding:2rem 1.5rem">
    <p style="font-size:11px;text-transform:uppercase;letter-spacing:.1em;color:rgba(245,230,211,0.5);margin-bottom:4px">Администрация</p>
    <h1 style="font-size:22px;font-weight:500;color:#f5e6d3;margin-bottom:0">Добави книга</h1>
</div>

<div class="container-fluid py-4" style="background:#faf7f2;min-height:60vh">
    <div style="max-width:520px;background:#fff;border:1px solid #e8e0d5;border-radius:10px;padding:1.5rem">
        <form asp-action="CreateBook" method="post">
            <div asp-validation-summary="ModelOnly" class="alert alert-danger" style="font-size:13px"></div>
            <div class="mb-3">
                <label asp-for="Title" style="font-size:13px;color:#7a5c3a;font-weight:500">Заглавие</label>
                <input asp-for="Title" class="form-control mt-1" style="border-color:#e8e0d5;font-size:14px" />
                <span asp-validation-for="Title" class="text-danger" style="font-size:12px"></span>
            </div>
            <div class="mb-3">
                <label asp-for="AuthorId" style="font-size:13px;color:#7a5c3a;font-weight:500">Автор</label>
                <select asp-for="AuthorId" asp-items="ViewBag.Authors" class="form-select mt-1" style="border-color:#e8e0d5;font-size:14px">
                    <option value="">-- Избери автор --</option>
                </select>
            </div>
            <div class="mb-3">
                <label asp-for="GenreId" style="font-size:13px;color:#7a5c3a;font-weight:500">Жанр</label>
                <select asp-for="GenreId" asp-items="ViewBag.Genres" class="form-select mt-1" style="border-color:#e8e0d5;font-size:14px">
                    <option value="">-- Избери жанр --</option>
                </select>
            </div>
            <div class="mb-3">
                <label asp-for="Year" style="font-size:13px;color:#7a5c3a;font-weight:500">Година</label>
                <input asp-for="Year" class="form-control mt-1" style="border-color:#e8e0d5;font-size:14px" />
                <span asp-validation-for="Year" class="text-danger" style="font-size:12px"></span>
            </div>
            <div class="mb-3">
                <label asp-for="TotalCopies" style="font-size:13px;color:#7a5c3a;font-weight:500">Брой копия</label>
                <input asp-for="TotalCopies" class="form-control mt-1" style="border-color:#e8e0d5;font-size:14px" />
            </div>
            <div class="mb-4">
                <label asp-for="Description" style="font-size:13px;color:#7a5c3a;font-weight:500">Описание</label>
                <textarea asp-for="Description" class="form-control mt-1" rows="3" style="border-color:#e8e0d5;font-size:14px"></textarea>
            </div>
            <div class="d-flex gap-2">
                <button type="submit" class="btn"
                        style="background:#5c3d2e;border-color:#5c3d2e;color:#f5e6d3;font-size:14px">
                    Запази
                </button>
                <a asp-action="Books" class="btn"
                   style="border:1px solid #d5c5b0;color:#5c3d2e;background:#fff;font-size:14px">Назад</a>
            </div>
        </form>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}