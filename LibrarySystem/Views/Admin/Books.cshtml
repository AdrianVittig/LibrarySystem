@model IEnumerable<LibrarySystem.Models.Book>
@{
    ViewData["Title"] = "Управление на книги";
}

<div style="background:#5c3d2e;padding:2rem 1.5rem">
    <p style="font-size:11px;text-transform:uppercase;letter-spacing:.1em;color:rgba(245,230,211,0.5);margin-bottom:4px">Администрация</p>
    <h1 style="font-size:22px;font-weight:500;color:#f5e6d3;margin-bottom:2px">Книги</h1>
    <p style="font-size:13px;color:rgba(245,230,211,0.55)">@Model.Count() заглавия в системата</p>
</div>

<div class="container-fluid py-4" style="background:#faf7f2;min-height:60vh">
    <partial name="_Alert" />
    <div class="d-flex justify-content-end mb-3">
        <a asp-action="CreateBook" class="btn"
           style="background:#5c3d2e;border-color:#5c3d2e;color:#f5e6d3;font-size:14px">+ Добави книга</a>
    </div>
    <div style="background:#fff;border:1px solid #e8e0d5;border-radius:10px;overflow:hidden">
        <table class="table mb-0" style="font-size:14px">
            <thead style="background:#f5ede0">
                <tr>
                    <th style="color:#7a5c3a;font-weight:500;border-bottom:1px solid #e8e0d5">Заглавие</th>
                    <th style="color:#7a5c3a;font-weight:500;border-bottom:1px solid #e8e0d5">Автор</th>
                    <th style="color:#7a5c3a;font-weight:500;border-bottom:1px solid #e8e0d5">Жанр</th>
                    <th style="color:#7a5c3a;font-weight:500;border-bottom:1px solid #e8e0d5">Налични</th>
                    <th style="border-bottom:1px solid #e8e0d5"></th>
                </tr>
            </thead>
            <tbody>
                @foreach (var book in Model)
                {
                    <tr style="border-bottom:1px solid #f5ede0">
                        <td style="color:#2c1810;vertical-align:middle">@book.Title</td>
                        <td style="color:#a08060;vertical-align:middle">@book.Author.FirstName @book.Author.LastName</td>
                        <td style="vertical-align:middle">
                            <span style="font-size:11px;background:#f5ede0;color:#7a5c3a;padding:2px 8px;border-radius:4px">@book.Genre.Name</span>
                        </td>
                        <td style="color:#888;vertical-align:middle">@book.AvailableCopies / @book.TotalCopies</td>
                        <td style="vertical-align:middle;text-align:right">
                            <a asp-action="EditBook" asp-route-id="@book.Id" class="btn btn-sm me-1"
                               style="border:1px solid #d5c5b0;color:#5c3d2e;background:#fff;font-size:12px">Редактирай</a>
                            <form asp-action="DeleteBook" asp-route-id="@book.Id" method="post" style="display:inline">
                                <button type="submit" class="btn btn-sm"
                                        style="border:1px solid #e8d5d5;color:#c0392b;background:#fff;font-size:12px"
                                        onclick="return confirm('Сигурен ли си?')">
                                    Изтрий
                                </button>
                            </form>
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
</div>