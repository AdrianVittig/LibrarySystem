@model LibrarySystem.ViewModels.RegisterViewModel
@{
    ViewData["Title"] = "Регистрация";
}

<div style="min-height:80vh;display:flex;align-items:center;justify-content:center;background:#faf7f2;padding:2rem 0">
    <div style="background:#fff;border:1px solid #e8e0d5;border-radius:12px;overflow:hidden;width:100%;max-width:380px">
        <div style="background:#5c3d2e;padding:1.5rem;text-align:center">
            <h2 style="color:#f5e6d3;font-size:18px;font-weight:500;margin:0">Регистрация</h2>
            <p style="color:rgba(245,230,211,0.55);font-size:13px;margin-top:4px;margin-bottom:0">Създай нов акаунт</p>
        </div>
        <div style="padding:1.5rem">
            <form asp-controller="Auth" asp-action="Register" method="post">
                <div asp-validation-summary="ModelOnly" class="alert alert-danger" style="font-size:13px"></div>
                <div class="row mb-3">
                    <div class="col">
                        <label asp-for="FirstName" style="font-size:13px;color:#7a5c3a;font-weight:500">Име</label>
                        <input asp-for="FirstName" class="form-control mt-1" style="border-color:#e8e0d5;font-size:14px" />
                        <span asp-validation-for="FirstName" class="text-danger" style="font-size:12px"></span>
                    </div>
                    <div class="col">
                        <label asp-for="LastName" style="font-size:13px;color:#7a5c3a;font-weight:500">Фамилия</label>
                        <input asp-for="LastName" class="form-control mt-1" style="border-color:#e8e0d5;font-size:14px" />
                        <span asp-validation-for="LastName" class="text-danger" style="font-size:12px"></span>
                    </div>
                </div>
                <div class="mb-3">
                    <label asp-for="Email" style="font-size:13px;color:#7a5c3a;font-weight:500">Email</label>
                    <input asp-for="Email" class="form-control mt-1" style="border-color:#e8e0d5;font-size:14px" />
                    <span asp-validation-for="Email" class="text-danger" style="font-size:12px"></span>
                </div>
                <div class="mb-3">
                    <label asp-for="Password" style="font-size:13px;color:#7a5c3a;font-weight:500">Парола</label>
                    <input asp-for="Password" class="form-control mt-1" style="border-color:#e8e0d5;font-size:14px" />
                    <span asp-validation-for="Password" class="text-danger" style="font-size:12px"></span>
                </div>
                <div class="mb-4">
                    <label asp-for="ConfirmPassword" style="font-size:13px;color:#7a5c3a;font-weight:500">Потвърди парола</label>
                    <input asp-for="ConfirmPassword" class="form-control mt-1" style="border-color:#e8e0d5;font-size:14px" />
                    <span asp-validation-for="ConfirmPassword" class="text-danger" style="font-size:12px"></span>
                </div>
                <button type="submit" class="btn w-100"
                        style="background:#5c3d2e;border-color:#5c3d2e;color:#f5e6d3;font-size:14px">
                    Регистрирай се
                </button>
                <a asp-controller="Auth" asp-action="Login"
                   class="btn btn-link w-100 mt-2"
                   style="color:#a08060;font-size:13px">Вече имаш акаунт? Влез</a>
            </form>
        </div>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}